# Copy this file to .env and fill in the values before running in production.
# For local development, these defaults are safe to leave as-is.

# Django secret key — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-in-production

# Set to "false" in production
DJANGO_DEBUG=true

# Comma-separated list of allowed hostnames in production
# Example: DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
